        <mxCell id="latch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#111827;arcSize=14;" value="LATCH_RESULT&#xa;• Zero-extend sample to 16 bits&#xa;• READY = 1&#xa;• BUSY = 0" vertex="1">
          <mxGeometry height="95" width="245" x="580" y="340" as="geometry" />
