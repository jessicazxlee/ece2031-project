        <mxCell id="idle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FB;strokeColor=#7A8A99;fontColor=#111827;arcSize=14;" value="IDLE&#xa;• BUSY = 0&#xa;• Wait for ADC_CTRL.START" vertex="1">
