        <mxCell id="statusnote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontColor=#374151;dashed=1;arcSize=12;" value="Status Register View&#xa;bit0 = READY&#xa;bit1 = BUSY" vertex="1">
